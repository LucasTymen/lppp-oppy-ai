# LPPP — Variables d'environnement (copier en .env et remplir)
# Ne jamais committer .env ni clés privées (cf. docs/base-de-connaissances/infra-devops.md)
#
# STACK AUTONOME (log commun § 5.3, § 5.4) : LPPP utilise UNIQUEMENT sa propre stack
# (lppp_web, lppp_n8n, lppp_flowise, lppp_db, lppp_redis). Aucune URL/host/port ne doit
# pointer vers SquidResearch (8000, 5679, 3001, 5432, 6379, etc.).

# Django
SECRET_KEY=change-me-in-production-lppp
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web
TIME_ZONE=Europe/Paris
CORS_ALLOWED_ORIGINS=

# Base de données (PostgreSQL — Docker ou local)
# Port LPPP dédié 5433 (SquidResearch 5432). Option B runserver : DB_HOST=localhost, DB_PORT=5433
DB_NAME=lppp
DB_USER=lpppuser
DB_PASSWORD=lppppass123
DB_HOST=db
DB_PORT=5432

# Redis (app data : résultats partiels enrichissement décomposé)
REDIS_URL=redis://redis:6379/0

# Celery (Redis)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# n8n (optionnel — auth basique si N8N_BASIC_AUTH_ACTIVE=true)
# Port LPPP dédié 5681 (pas 5678/5679 SquidResearch). Stack autonome : pas d'URL vers SquidResearch.
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5681/
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
TZ=Europe/Paris

# Flowise (optionnel — accès UI ; clés LLM/embedding dans l’interface Flowise)
# Voir data/flowise/comptes-et-llm.md pour la liste des comptes et modèles à configurer.
FLOWISE_USERNAME=
FLOWISE_PASSWORD=
# Push documents + embed chatbot : port LPPP dédié 3010 (pas 3000/3001 SquidResearch). Stack autonome.
# Dans Docker les services utilisent http://flowise:3000 en interne ; pour le navigateur : localhost:3010
FLOWISE_URL=http://localhost:3010
FLOWISE_DOCUMENT_STORE_ID=
# FLOWISE_API_KEY=   # optionnel si Flowise exige un token API
# Interface de test chatbot (/essais/concierge/, landings élus) : ID du chatflow (visible dans Flowise → Embed)
# FLOWISE_CHATFLOW_ID=

# Style perso (fallback) : chemin vers projet landing CV / page perso (graphiques, infographiques)
# Linux/WSL : /home/lucas/lucasTymenGraphx/landingpageCvPagePerso
# Windows (WSL) : \\wsl$\Ubuntu\home\lucas\lucasTymenGraphx\landingpageCvPagePerso
# LANDING_PERSO_REF_PATH=/home/lucas/lucasTymenGraphx/landingpageCvPagePerso
