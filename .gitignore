# LPPP — Ne jamais committer de données sensibles (cf. docs/base-de-connaissances/infra-devops.md)

# ---- Secrets et credentials ----
# .env : Django + Flowise (FLOWISE_USERNAME, FLOWISE_PASSWORD, FLOWISE_URL, FLOWISE_DOCUMENT_STORE_ID, etc.) — ne jamais committer
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.staging
*.env
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/
*.credentials
*.token
.vercel

# ---- Flowise (contenu à ingérer : généré / scrapé, ne pas versionner) ----
data/flowise/*.txt
# Index FAISS (binaires, générés par Flowise) — un dossier par RAG sous data/flowise/faiss/<projet>
data/flowise/faiss/*/

# ---- Sauvegardes PostgreSQL (make backup) — ne pas versionner les dumps ----
backups/

# ---- Message de commit temporaire (script) ----
.git_commit_msg.txt

# ---- Deploy (clones temporaires) ----
deploy/repo-p4s/
deploy/repo-*/

# ---- Node.js (ne jamais pousser node_modules) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.venv/
.venv.wsl/
venv/
env/
.env/
*.egg-info/
.eggs/
dist/
build/
*.egg

# ---- Django ----
*.sqlite3
*.sqlite3-journal
staticfiles/
media/
local_settings.py
db.sqlite3

# ---- Logs et dumps (peuvent contenir des données sensibles) ----
*.log
logs/*.log
*.log.*
*.dump
*.sql
*.bak
*.backup

# ---- Tests et couverture ----
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/
coverage.xml
*.cover

# ---- IDE et éditeurs ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*

# ---- OS ----
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# ---- Docker (optionnel, selon convention) ----
# docker-compose.override.yml contient souvent des secrets locaux
docker-compose.override.yml
.docker/

# ---- Autres ----
*.tmp
*.temp
.cache/
